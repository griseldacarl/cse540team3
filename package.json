{
  "name": "government-supply-chain-project",
  "private": true,
  "scripts": {
    "install-all": "npm --prefix src/backend install && npm --prefix src/frontend install",
    "compile": "npx hardhat compile",
    "start-hardhat": "npx hardhat node",
    "deploy": "npx hardhat run src/frontend/src/scripts/deploy.js --network localhost",
    "backend": "cd src/backend && npm run dev",
    "frontend": "cd src/frontend && npm start",
    "start-all": "npx concurrently \"npm run backend\" \"npm run frontend\"",
    "dev": "npm run install-all && npm run start-all",
    "quick-dev": "npm run start-all"
  },
  "dependencies": {
    "dotenv": "17.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "hardhat": "^2.26.0",
    "@nomicfoundation/hardhat-toolbox": "^5"
  }
}